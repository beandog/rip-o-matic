#!/usr/bin/env bash

export_dir="/home/steve/Media/Plex"

cd $export_dir

toilet -f future '* Rip-o-Matic *' --filter metal

while true; do

	random_iso="$(/home/steve/Videos/Rip-o-Matic/wheel-o-fun)"
	test -z "$random_iso" && exit
	random_iso_basename="$(basename $random_iso)"

	series_id=$(echo $random_iso_basename | cut -d '.' -f 2);
	dvd_id=$(echo $random_iso_basename | cut -d '.' -f 3);
	dvd_url_id=$(echo $dvd_id | sed 's/^0*//')
	series_title=$(psql -h dlna -c "SELECT title FROM series WHERE id = $series_id;" -q --csv dvds | tail -n 1)

	echo "* $series_title ($series_id)"
	echo "* http://dlna.beandog.org/index.php/dvds/episodes/${dvd_url_id}"

	is_encoding=$(pgrep -l "^(HandBrakeCLI|ffmpeg).+${random_iso_basename}" -c)

	if [[ "$is_encoding" -ge 1 ]]; then echo "* DVD already being washed, spin again"; exit 1; fi
	# echo "* Ready to wash $random_iso_basename !"

	dart --encode --skip-existing --test-existing --time --log-progress --export-dir "$export_dir" "$random_iso"
	e=$?

	if [[ $e -ne 0 ]]; then
		exit 1
	fi

	echo "[ `date` - $random_iso_basename ] - Fluff-Puff, Encode Finished :D" | tee -a /home/steve/Videos/Rip-o-Matic/event.log
	echo "$random_iso can be safely removed" | tee -a /home/steve/Videos/Rip-o-Matic/event.log

done
